# Copy to .env and edit. .env is gitignored.

# Image tag - choose your Asterisk major version:
#   latest, stable    - rolling latest stable (currently 22.x)
#   23, 22, 21, 20    - track latest minor of that major
#   22.10.1_debian-trixie - pin an exact build
#   testing, dev      - latest git build (advanced; less stable)
ASTERISK_TAG=latest

# UID/GID owning your bind-mounted host volumes (only relevant if you
# replace the named volumes with bind mounts; named volumes inherit
# whatever UID the entrypoint sets).
# Asterisk 10.x+ images respect these and chown the runtime dirs at boot.
PUID=1000
PGID=1000
